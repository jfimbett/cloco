# Secrets and local configuration
.env
.env.local
.claude/settings.local.json
.claude/state/
.claude/plans/
.claude/specs/

# Data files — never commit raw or processed data
# Folder structure (.gitkeep files) is tracked; data files are not
data/raw/**
!data/raw/**/.gitkeep
data/processed/**
!data/processed/.gitkeep

# Common data file formats
*.parquet
*.csv
*.dta
*.sas7bdat
*.feather
*.arrow
*.h5
*.hdf5
*.pkl
*.pickle
*.rds
*.RData

# LaTeX build artifacts
*.aux
*.log
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.out
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
*.bcf
*.run.xml
*.xdv
paper/**/*.pdf

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
*.swp
*.swo
*~
